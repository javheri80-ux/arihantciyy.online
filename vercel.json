{
  "cleanUrls": true,
  "functions": {
    "*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "headers": [
    {
      "source": "/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" },
        { "key": "Content-Type", "value": "image/webp" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/admin",
      "destination": "/admin.php"
    },
    {
      "source": "/contact",
      "destination": "/contact.php"
    },
    {
      "source": "/leads",
      "destination": "/baba-leads.php"
    },
    {
      "source": "/((?!images|blog|robots\\.txt|sitemap\\.xml).*)",
      "destination": "/index.php"
    }
  ]
}
