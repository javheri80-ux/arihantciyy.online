{
  "functions": {
    "*.php": {
      "runtime": "vercel-php@0.7.1"
    }
  },
  "routes": [
    {
      "src": "/(index.php)?",
      "dest": "index.php"
    },
    {
      "src": "/admin(.php)?",
      "dest": "admin.php"
    },
    {
      "src": "/contact(.php)?",
      "dest": "contact.php"
    }
  ]
}
